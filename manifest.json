{
  "manifest_version": 3,
  "name": "Auto Page Translator",
  "description": "Automatically translates configured pages to English.",
  "version": "1.0.0",
  "icons": {
    "16": "icons/idle-16.png",
    "32": "icons/idle-32.png",
    "48": "icons/idle-48.png",
    "128": "icons/idle-128.png"
  },
  "permissions": [
    "contextMenus",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_icon": {
      "16": "icons/idle-16.png",
      "32": "icons/idle-32.png",
      "48": "icons/idle-48.png",
      "128": "icons/idle-128.png"
    },
    "default_popup": "popup/popup.html",
    "default_title": "Auto Page Translator"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "options_page": "options/options.html"
}
